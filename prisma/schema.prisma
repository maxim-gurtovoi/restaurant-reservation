generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MANAGER
  OWNER
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  CHECKED_IN
  COMPLETED
  NO_SHOW
}

enum TableShape {
  RECTANGLE
  ROUND
  SQUARE
}

enum CheckInMethod {
  QR
  MANUAL
}

enum FloorPlanElementType {
  BAR_COUNTER
  STAGE
  STAIRS
  FIREPLACE
  WINDOW
  DOOR
  WALL
  PLANT
  PILLAR
  RESTROOM
  KITCHEN
  HOST_STAND
  TERRACE_RAILING
  SMOKER
}

enum RestaurantFeature {
  CARD_PAYMENT
  DELIVERY
  TAKEAWAY
  TERRACE
  LIVE_MUSIC
  PARKING
  WIFI
  PET_FRIENDLY
  FAMILY_FRIENDLY
  RESERVATIONS
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations       Reservation[]
  adminRestaurants   RestaurantAdmin[]
  checkInLogs        CheckInLog[]
  managedRestaurant  Restaurant? @relation("RestaurantManager")

  @@index([role])
}

model Restaurant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  address     String
  phone       String?
  email       String?
  /// IANA zone (e.g. Europe/Chisinau). Null = use APP_TIMEZONE from env.
  timeZone    String?
  imageUrl    String?
  /// Wide hero cover shown on the detail page (distinct from the list thumbnail).
  coverImageUrl String?
  cuisine       String?
  /// Price tier 1..4, rendered as $/$$/$$$/$$$$ with a localized hint.
  priceLevel    Int?
  websiteUrl    String?
  instagramUrl  String?
  facebookUrl   String?
  googleMapsUrl String?
  /// Aggregate rating 0..5 (kept as a scalar; no Review model yet).
  rating        Float?
  reviewsCount  Int       @default(0)
  features      RestaurantFeature[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Hall manager (one restaurant — one manager user).
  managerUserId String? @unique @db.Uuid
  manager       User?   @relation("RestaurantManager", fields: [managerUserId], references: [id])

  floorPlans  FloorPlan[]
  tables      RestaurantTable[]
  reservations Reservation[]
  workingHours WorkingHours[]
  admins      RestaurantAdmin[]

  @@index([isActive])
}

model RestaurantAdmin {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  restaurantId String     @db.Uuid
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

model FloorPlan {
  id                String           @id @default(uuid()) @db.Uuid
  restaurantId      String           @db.Uuid
  name              String
  width             Int
  height            Int
  backgroundImageUrl String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  tables     RestaurantTable[]
  elements   FloorPlanElement[]

  @@index([restaurantId])
}

model FloorPlanElement {
  id          String                @id @default(uuid()) @db.Uuid
  floorPlanId String                @db.Uuid
  type        FloorPlanElementType
  x           Int
  y           Int
  width       Int
  height      Int
  rotation    Int                   @default(0)
  label       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  floorPlan   FloorPlan             @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)

  @@index([floorPlanId])
}

model RestaurantTable {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @db.Uuid
  floorPlanId  String   @db.Uuid
  label        String
  capacity     Int
  shape        TableShape
  x            Int
  y            Int
  width        Int
  height       Int
  rotation     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id])
  floorPlan   FloorPlan   @relation(fields: [floorPlanId], references: [id])
  reservations Reservation[]

  @@unique([floorPlanId, label])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model WorkingHours {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @db.Uuid
  dayOfWeek    Int     // 0-6 (Sunday-Saturday) or 1-7, application decides
  openTime     String  // e.g. "10:00"
  closeTime    String  // e.g. "22:00"
  isClosed     Boolean @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
}

model Reservation {
  id           String            @id @default(uuid()) @db.Uuid
  /// Null = гостевая бронь (контакты в contact*).
  userId       String?           @db.Uuid
  restaurantId String            @db.Uuid
  tableId      String            @db.Uuid
  guestCount   Int
  startAt      DateTime
  endAt        DateTime
  status       ReservationStatus @default(CONFIRMED)
  qrToken      String            @unique
  /// Human-readable 7-digit code shown in UI and used for manual lookup.
  referenceCode String           @unique
  contactName  String
  contactPhone String?
  contactEmail String?
  notes        String?
  checkedInAt  DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       User?           @relation(fields: [userId], references: [id])
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  table      RestaurantTable @relation(fields: [tableId], references: [id])
  checkInLogs CheckInLog[]

  @@index([userId, startAt])
  @@index([restaurantId, startAt])
  @@index([restaurantId, tableId, startAt])
  @@index([tableId, status, startAt, endAt])
  @@index([restaurantId, tableId, status, startAt, endAt])
  @@index([status])
}

model CheckInLog {
  id                String         @id @default(uuid()) @db.Uuid
  reservationId     String         @db.Uuid
  checkedInByUserId String         @db.Uuid
  checkedInAt       DateTime       @default(now())
  method            CheckInMethod
  notes             String?

  reservation Reservation @relation(fields: [reservationId], references: [id])
  checkedInBy User        @relation(fields: [checkedInByUserId], references: [id])

  @@index([reservationId])
  @@index([checkedInByUserId])
}

